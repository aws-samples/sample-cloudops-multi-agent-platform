{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DxVisualizerCore",
      "Effect": "Allow",
      "Action": [
        "directconnect:DescribeConnections",
        "directconnect:DescribeVirtualInterfaces",
        "directconnect:DescribeDirectConnectGateways",
        "directconnect:DescribeDirectConnectGatewayAssociations",
        "directconnect:DescribeDirectConnectGatewayAssociationProposals",
        "directconnect:DescribeLocations",
        "directconnect:DescribeLags",
        "ec2:DescribeVpcs",
        "ec2:DescribeVpnGateways",
        "ec2:DescribeTransitGateways",
        "ec2:DescribeTransitGatewayAttachments",
        "ec2:DescribeTransitGatewayPeeringAttachments",
        "ec2:DescribeVpcPeeringConnections",
        "ec2:DescribeCustomerGateways",
        "ec2:DescribeVpnConnections",
        "ec2:DescribeTransitGatewayRouteTables",
        "ec2:SearchTransitGatewayRoutes",
        "networkmanager:ListCoreNetworks",
        "networkmanager:GetCoreNetwork",
        "networkmanager:ListAttachments",
        "networkmanager:ListPeerings",
        "networkmanager:GetNetworkRoutes",
        "cloudwatch:GetMetricData",
        "cloudwatch:ListMetrics",
        "sts:GetCallerIdentity"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DxVisualizerMaintenanceEvents",
      "Effect": "Allow",
      "Action": [
        "health:DescribeEvents",
        "health:DescribeEventDetails",
        "health:DescribeAffectedEntities"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DxVisualizerCostAndPricing",
      "Effect": "Allow",
      "Action": [
        "ce:GetCostAndUsage",
        "pricing:GetProducts"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DxVisualizerAIChat",
      "Effect": "Allow",
      "Action": [
        "bedrock:InvokeModelWithResponseStream"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DxVisualizerAccountName",
      "Effect": "Allow",
      "Action": [
        "organizations:DescribeAccount",
        "iam:ListAccountAliases"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DxVisualizerCrossAccount",
      "Effect": "Allow",
      "Action": [
        "sts:AssumeRole"
      ],
      "Resource": "arn:aws:iam::*:role/NetworkReadOnlyRole"
    },
    {
      "Sid": "DxVisualizerRegionNames",
      "Effect": "Allow",
      "Action": [
        "ssm:GetParameters"
      ],
      "Resource": "arn:aws:ssm:*::parameter/aws/service/global-infrastructure/*"
    }
  ]
}
